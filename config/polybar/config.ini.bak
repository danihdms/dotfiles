[colors]
background =  #993a4953
background-alt = #373B41
foreground = #C5C8C6
primary = #5086BB
secondary = #8ABEB7
alert = #A54242
disabled = #707880
white = #FFFFFF

[bar/bar1]
width = 95%
height = 22
offset-x = 2.5%
offset-y = 0.7%
radius = 9
; monitor = ${env:MONITOR:}
monitor = eDP1

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2pt

padding-left = 0
padding-right = 1

module-margin = 1

separator = "  | "
separator-foreground = ${colors.disabled}

font-0 = "Hack Nerd Font:size=10;2"

modules-left = i3 xwindow
modules-center = date
modules-right = battery pulseaudio xkeyboard memory cpu wlan time 

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true

; tray-position = right
wm-restack = i3

override-redirect = true

[bar/bar2]
width = 95%
height = 22
offset-x = 2.5%
offset-y = 0.7%
radius = 9
monitor = DP1

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2pt

padding-left = 0
padding-right = 1

module-margin = 1

separator = "  | "
separator-foreground = ${colors.disabled}

font-0 = "Hack Nerd Font:size=10;2"

modules-left = i3 xwindow
modules-center = date
modules-right = battery pulseaudio xkeyboard memory cpu wlan time 

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true

; tray-position = right
wm-restack = i3

override-redirect = true

[module/i3]
type = internal/i3

ws-icon-0 = 1;ÔĄ° 
ws-icon-1 = 2;ÔČß 
ws-icon-2 = 3;ÔĀĶ 
ws-icon-3 = 4;ÔäĘ 
ws-icon-4 = 5;ÔÄ• 
ws-icon-5 = 6;ÔČī 
ws-icon-6 = 7;ÔÉ† 
ws-icon-7 = 8;ÔĄõ 
ws-icon-8 = 9;ÔāĪ 
ws-icon-9 = 10;Ôąī 
ws-icon-default = a 

format = <label-state>
format-background = ${colors.background}

label-focused = %icon%
label-focused-padding = 1
label-focused-foreground = ${colors.primary}

label-unfocused = %icon%
label-unfocused-padding = 1
label-unfocused-foreground = ${colors.secondary}

label-visible = %icon%
label-visible-padding = 1
label-visible-foreground = ${colors.secondary}

label-urgent = %icon%
label-urgent-padding = 1
label-urgent-foreground = ${colors.secondary}

label-empty = %icon%
label-empty-padding = 1
label-empty-foreground = ${colors.secondary}

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP0
full-at = 100 

format-charging = <label-charging> <ramp-capacity>
format-discharging = <ramp-capacity> <label-discharging>
format-full = <ramp-capacity> <label-full>
label-charging = ůĪźč
label-discharging = 
label-charging-foreground = ${colors.primary}
label-discharging-foreground = ${colors.primary}
label-full = Ôēł
label-full-foreground = ${colors.primary}

ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ
ramp-capacity-foreground = ${colors.foreground}
 
[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#F0C674}%mountpoint%%{F-} %percentage_used%%

label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.disabled}

[module/pulseaudio]
type = internal/pulseaudio

format-volume-prefix = "ÔÄ® "
format-volume-prefix-foreground = ${colors.primary}
format-volume = <label-volume>

label-volume = %percentage%%

label-muted = muted
label-muted-foreground = ${colors.disabled}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "ÔĄú  "
format-prefix-foreground = ${colors.primary}

label-layout = %layout%
label-layout-foreground = ${colors.foreground}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-foreground = ${colors.background}
label-indicator-background = ${colors.secondary}

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ÓČÄ  "
format-prefix-foreground = ${colors.primary}
label = %percentage_used:2%%

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "Ôčõ "
format-prefix-foreground = ${colors.primary}
label = %percentage:2%%

[network-base]
type = internal/network
interval = 5
format-connected = <label-connected>
format-disconnected = <label-disconnected>
label-disconnected = %{F#F0C674}%ifname%%{F#707880} disconnected

[module/wlan]
inherit = network-base
interface-type = wireless
format-connected-prefix = "Ôáę  "
format-connected-prefix-foreground = ${colors.primary}
label-connected = %essid% 

[module/date]
type = internal/date
interval = 1

date = %A %m %Y

label = %date%
label-foreground = ${colors.primary}

[module/time]
type = internal/date
interval = 1

time = %H:%M

label = %time%
; label-foreground = ${colors.primary}
label-foreground = ${colors.white}

[settings]
screenchange-reload = true
pseudo-transparency = true

; vim:ft=dosini
;
[bar/example]
